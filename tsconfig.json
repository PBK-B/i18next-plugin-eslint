{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "node",
        "strict": true,
        "noImplicitAny": false,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "rootDir": "src"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "dist",
        "types",
        "node_modules"
    ]
}